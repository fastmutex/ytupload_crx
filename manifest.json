{
  "manifest_version": 3,
  "name": "YT Bulk Upload",
  "version": "2.0.0",
  "description": "Bulk-upload many videos to YouTube Studio in one pick, bypassing the 15-file selection limit",
  "host_permissions": [
    "https://studio.youtube.com/*"
  ],
  "action": {
    "default_title": "Open YouTube Studio bulk upload"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://studio.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
